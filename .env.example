# ─── Ollama ────────────────────────────────────────────────────────────────────
# URL do servidor Ollama (padrão: roda localmente)
# OLLAMA_BASE_URL=http://localhost:11434

# Modelo a usar — deve estar baixado via: ollama pull <modelo>
# Opções recomendadas:
#   gemma3:4b   → ~4 GB RAM  (padrão, boa qualidade)
#   llama3.2:3b → ~3 GB RAM  (mais leve)
#   mistral     → ~5 GB RAM  (excelente em português)
#   phi4-mini   → ~2.5 GB RAM (ultraleve)
# OLLAMA_MODEL=gemma3:4b

# ─── Memória ───────────────────────────────────────────────────────────────────
# Quantos pares de mensagens (usuário + assistente) são enviados ao modelo
# como contexto. Valores menores = respostas mais rápidas.
# MAX_TURNS=5

# ─── Voz (TTS) ─────────────────────────────────────────────────────────────────
# Flag para habilitar ou desabilitar a fala. Útil para testar sem gastar tokens.
# Pode ser setado para True ou False.
# TTS_ENABLED=False

# Credenciais da Azure usadas pelo motor AzureEngine
# AZURE_SPEECH_KEY=sua_chave_aqui
# AZURE_SPEECH_REGION=brazilsouth

# Qual voz o sistema deve usar na Azure:

# AZURE_SPEECH_VOICE=pt-BR-ThalitaNeural
